{
    "containerDefinitions": [
        {
            "name": "docker",
            "image": "<IMAGE_URI>",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "name": "docker-8000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "DB_NAME",
                    "value": "docker"
                },
                {
                    "name": "DB_HOST",
                    "value": "database-do.cvvgrxetc5th.us-east-1.rds.amazonaws.com"
                },
                {
                    "name": "DB_PASS",
                    "value": "postgres123"
                },
                {
                    "name": "DB_USER",
                    "value": "postgres"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/dockerr",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "dockerr",
    "taskRoleArn": "arn:aws:iam::022110739617:role/LabRole",
    "executionRoleArn": "arn:aws:iam::022110739617:role/LabRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "3072",
    "enableFaultInjection": false
}